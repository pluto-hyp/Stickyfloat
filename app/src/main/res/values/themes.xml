<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.StickyFloat" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/yellow_primary</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:statusBarColor">@color/background_dark</item>
        <item name="android:navigationBarColor">@color/background_dark</item>
    </style>

    <style name="Theme.StickyFloat.Translucent" parent="Theme.StickyFloat">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:backgroundDimEnabled">true</item>
    </style>

    <style name="NoteDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog.Centered">
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">#FFFFFF</item>
        <item name="colorPrimary">@color/yellow_primary</item>
    </style>
</resources>