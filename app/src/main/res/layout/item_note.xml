<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/surface_dark"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:strokeColor="#33FFFFFF"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvContent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:lineSpacingMultiplier="1.3" />

            <ImageButton
                android:id="@+id/btnAiExpand"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="@string/editBtn"
                android:src="@drawable/ic_ai"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_marginStart="4dp"
                app:tint="#AAFFD700" />

            <ImageButton
                android:id="@+id/btnEdit"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="@string/editBtn"
                android:src="@drawable/ic_edit"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_marginStart="4dp"
                app:tint="#AAFFD700" />

            <ImageButton
                android:id="@+id/btnDelete"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="@string/deleteBtn"
                android:src="@drawable/ic_delete"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="#AA888888"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#66FFFFFF"
            android:textSize="11sp"
            android:layout_marginTop="6dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#22FFFFFF"
            android:layout_marginVertical="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipStatus"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                app:chipBackgroundColor="#1AFFD700"
                app:chipStrokeColor="@color/yellow_primary"
                app:chipStrokeWidth="1dp"
                android:textColor="@color/yellow_primary"
                android:textSize="11sp"
                android:layout_marginEnd="8dp"
                android:clickable="false"
                app:ensureMinTouchTargetSize="false" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnInProgress"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="64dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:paddingHorizontal="8dp"
                android:text="@string/inProgressIcon"
                android:textSize="24sp"
                app:strokeColor="#446699FF" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDone"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="64dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:paddingHorizontal="8dp"
                android:text="@string/doneIcon"
                android:textSize="24sp"
                app:strokeColor="#4444BB44" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelled"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="64dp"
                android:layout_height="wrap_content"
                android:text="@string/cancelIcon"
                android:textSize="24sp"
                android:paddingHorizontal="8dp"
                app:strokeColor="#44BB4444" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>